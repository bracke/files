with "config/tests_config.gpr";
project Tests is

   for Source_Dirs use ("tests/src/", "config/");
   for Object_Dir use "obj/" & Tests_Config.Build_Profile;
   for Create_Missing_Dirs use "True";
   for Exec_Dir use "bin";
   for Main use ("tests.adb");

   package Compiler is
      for Default_Switches ("Ada") use
        Tests_Config.Ada_Compiler_Switches & ("-gnat2022", "-gnatyM120", "-gnatX", "-gnatwU");
   end Compiler;

   package Binder is
      for Switches ("Ada") use ("-Es"); --  Symbolic traceback
   end Binder;

   package Linker is
      for Default_Switches ("Ada") use ("-lvulkan");
   end Linker;

   package Builder is
      for Executable ("tests.adb") use "tests";
   end Builder;

   package Install is
      for Artifacts (".") use ("tests/share");
   end Install;

end Tests;
