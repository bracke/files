           Files.Events.Translate_Scroll_At
             (Snapshot => Palette_Snapshot,
              X        => Palette.Results_X + 1,
              Y        => Palette.Results_Y + 1,
              Width    => 1000,
              Height   => 800,
              Y_Offset => -1);
