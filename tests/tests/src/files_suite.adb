      Files.Model.Move_Selection (Model, Files.Types.Move_Right);
      Assert (Files.Model.Selected_Index (Model) = 1, "right from last wraps to first after up wrap");
      Files.Model.Move_Selection (Model, Files.Types.Move_Down);
