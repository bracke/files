               Ada.Environment_Variables.Set ("COMSPEC", To_String (Old_Comspec));
            else
               Ada.Environment_Variables.Clear ("COMSPEC");
            end if;

            if Had_Shell then
               Ada.Environment_Variables.Set ("SHELL", To_String (Old_Shell));
            else
               Ada.Environment_Variables.Clear ("SHELL");
