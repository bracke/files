      Frame := Files.Rendering.Build_Frame_Commands (Snapshot, Width => 1000, Height => 800, Line_Height => 20);
      declare
         Drag_Frame         : constant Files.Rendering.Frame_Commands :=
           Files.Rendering.Build_Frame_Commands
             (Snapshot,
              Width           => 1000,
              Height          => 800,
              Line_Height     => 20,
