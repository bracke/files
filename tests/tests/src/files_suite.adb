              and then Command.Y = Bottom_Y
              and then Command.Width = Bottom.Info_Pane_Width
              and then Command.Height = 20 + Files.UI.Bottom_Bar_Padding * 2
              and then Command.Color = Files.Rendering.Selection_Color
