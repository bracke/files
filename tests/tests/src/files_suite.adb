         Exact_Ellipsis_Frame    : Files.Rendering.Frame_Commands;
         Found_Exact_Ellipsis    : Boolean := False;
         Details_Snapshot   : Files.Rendering.View_Snapshot;
         Details_Frame      : Files.Rendering.Frame_Commands;
      begin
