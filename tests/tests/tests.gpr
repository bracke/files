with "config/tests_config.gpr";
project Tests is

   for Source_Dirs use ("src/", "config/");
   for Object_Dir use "obj/" & Tests_Config.Build_Profile;
   for Create_Missing_Dirs use "True";
   for Exec_Dir use "bin";
   for Main use ("tests.adb", "noop.adb", "failing.adb", "marker.adb");

   package Compiler is
      for Default_Switches ("Ada") use
        Tests_Config.Ada_Compiler_Switches & ("-gnat2022", "-gnatyM120", "-gnatX", "-gnatwU");
   end Compiler;

   package Binder is
      for Switches ("Ada") use ("-Es"); --  Symbolic traceback
   end Binder;

   --  Mirrors the Linker package in files.gpr: the suite links the application's
   --  own code, so it needs the same native libraries. Keep the two in step.
   package Linker is
      case Tests_Config.Alire_Host_OS is
         when "macos" =>
            for Default_Switches ("Ada") use
              ("-lvulkan", "-lgdk_pixbuf-2.0", "-lgobject-2.0", "-lglib-2.0",
               "-framework", "CoreFoundation", "-framework", "CoreServices",
               "-framework", "Foundation");
         when "windows" =>
            --  The Vulkan loader is named vulkan-1 on Windows (vulkan-1.dll),
            --  not vulkan.
            for Default_Switches ("Ada") use
              ("-lvulkan-1", "-lgdk_pixbuf-2.0", "-lgobject-2.0", "-lglib-2.0",
               "-lshell32", "-lole32", "-lkernel32");
         when others =>
            for Default_Switches ("Ada") use
              ("-lvulkan", "-lgdk_pixbuf-2.0", "-lgobject-2.0", "-lglib-2.0");
      end case;
   end Linker;

   package Builder is
      for Executable ("tests.adb") use "tests";
   end Builder;

   package Install is
      for Artifacts (".") use ("share");
   end Install;

end Tests;
