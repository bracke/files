<?xml version="1.0" encoding="UTF-8" ?>
<ldml>
  <identity>
    <language type="zz"/>
    <territory type="ZZ"/>
  </identity>
  <numbers>
    <symbols numberSystem="latn">
      <decimal>*</decimal>
      <group>_</group>
    </symbols>
  </numbers>
  <units>
    <unitLength type="short">
      <unit type="digital-byte">
        <unitPattern count="other">{0}zb</unitPattern>
      </unit>
      <unit type="digital-kilobyte">
        <unitPattern count="other">{0}zkb</unitPattern>
      </unit>
      <unit type="digital-megabyte">
        <unitPattern count="other">{0}zmb</unitPattern>
      </unit>
      <unit type="digital-gigabyte">
        <unitPattern count="other">{0}zgb</unitPattern>
      </unit>
      <unit type="digital-terabyte">
        <unitPattern count="other">{0}ztb</unitPattern>
      </unit>
      <unit type="digital-petabyte">
        <unitPattern count="other">{0}zpb</unitPattern>
      </unit>
    </unitLength>
  </units>
  <dates>
    <calendars>
      <calendar type="gregorian">
        <months>
          <monthContext type="format">
            <monthWidth type="abbreviated">
              <month type="1">M1</month>
              <month type="2">M2</month>
              <month type="3">M3</month>
              <month type="4">M4</month>
              <month type="5">M5</month>
              <month type="6">M6</month>
              <month type="7">M7</month>
              <month type="8">M8</month>
              <month type="9">M9</month>
              <month type="10">M10</month>
              <month type="11">M11</month>
              <month type="12">M12</month>
            </monthWidth>
            <monthWidth type="wide">
              <month type="1">Month One</month>
              <month type="2">Month Two</month>
              <month type="3">Month Three</month>
              <month type="4">Month Four</month>
              <month type="5">Month Five</month>
              <month type="6">Month Six</month>
              <month type="7">Month Seven</month>
              <month type="8">Month Eight</month>
              <month type="9">Month Nine</month>
              <month type="10">Month Ten</month>
              <month type="11">Month Eleven</month>
              <month type="12">Month Twelve</month>
            </monthWidth>
          </monthContext>
        </months>
        <days>
          <dayContext type="format">
            <dayWidth type="abbreviated">
              <day type="mon">Mo</day>
              <day type="tue">Tu</day>
              <day type="wed">We</day>
              <day type="thu">Th</day>
              <day type="fri">Fr</day>
              <day type="sat">Sa</day>
              <day type="sun">Su</day>
            </dayWidth>
            <dayWidth type="wide">
              <day type="mon">Monday Z</day>
              <day type="tue">Tuesday Z</day>
              <day type="wed">Wednesday Z</day>
              <day type="thu">Thursday Z</day>
              <day type="fri">Friday Z</day>
              <day type="sat">Saturday Z</day>
              <day type="sun">Sunday Z</day>
            </dayWidth>
          </dayContext>
        </days>
        <dayPeriods>
          <dayPeriodContext type="format">
            <dayPeriodWidth type="wide">
              <dayPeriod type="am">ZA</dayPeriod>
              <dayPeriod type="pm">ZP</dayPeriod>
            </dayPeriodWidth>
          </dayPeriodContext>
        </dayPeriods>
        <dateFormats>
          <dateFormatLength type="medium">
            <dateFormat>
              <pattern>d MMM y</pattern>
            </dateFormat>
          </dateFormatLength>
        </dateFormats>
        <timeFormats>
          <timeFormatLength type="medium">
            <timeFormat>
              <pattern>HH.mm.ss</pattern>
            </timeFormat>
          </timeFormatLength>
        </timeFormats>
        <dateTimeFormats>
          <dateTimeFormatLength type="medium">
            <dateTimeFormat>
              <pattern>{1} at {0}</pattern>
            </dateTimeFormat>
          </dateTimeFormatLength>
        </dateTimeFormats>
        <fields>
          <field type="day">
            <relative type="-1">Yesterday Z</relative>
            <relative type="0">Today Z</relative>
          </field>
        </fields>
      </calendar>
    </calendars>
  </dates>
</ldml>
